rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasCustomClaim(role) {
      return request.auth.token.get('role', '') == role;
    }

    function getUserRole() {
      let claimRole = request.auth.token.get('role', '');
      return claimRole != '' ? claimRole :
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) ?
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role : '');
    }

    function isAdmin() {
      return isAuthenticated() && (hasCustomClaim('admin') || getUserRole() == 'admin');
    }

    function isMedecin() {
      return isAuthenticated() && getUserRole() == 'medecin';
    }

    function isAssistante() {
      return isAuthenticated() && getUserRole() == 'assistante';
    }

    function hasAccess() {
      return isAuthenticated() && (isAdmin() || isMedecin() || isAssistante());
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Settings — Admin uniquement
    // ===============================================================
    match /settings/{settingId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ===============================================================
    // Users
    // ===============================================================
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (
        (isOwner(userId) && request.resource.data.role != 'admin') || 
        isAdmin()
      ) && request.resource.data.keys().hasAll(['nom', 'prenom', 'email', 'role', 'actif', 'date_creation']);
      allow update: if isAuthenticated() && (
        (isOwner(userId) 
          && request.resource.data.role == resource.data.role 
          && request.resource.data.get('actif', true) == resource.data.get('actif', true) 
          && request.resource.data.email == resource.data.email
        ) || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ===============================================================
    // Patients
    // ===============================================================
    match /patients/{patientId} {
      allow read: if hasAccess();
      allow create: if hasAccess() && request.resource.data.keys().hasAll(['nom', 'prenom', 'telephone', 'created_by', 'created_at', 'updated_at']) && (
        !isAssistante() ||
        request.resource.data.keys().hasOnly([
          'nom', 'prenom', 'date_naissance', 'sexe', 'cin', 'telephone', 'adresse', 
          'profession', 'statut_familial', 'num_dossier', 'mutuelle', 'amo', 
          'num_cnss', 'origine_patient', 'detail_origine', 'allergies', 'poids', 
          'created_by', 'created_at', 'updated_at'
        ])
      );
      allow update: if hasAccess() && (
        !isAssistante() || 
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'nom', 'prenom', 'date_naissance', 'sexe', 'cin', 'telephone', 'adresse', 
            'profession', 'statut_familial', 'num_dossier', 'mutuelle', 'amo', 
            'num_cnss', 'origine_patient', 'detail_origine', 'allergies', 'poids', 
            'updated_at'
          ])
        )
      );
      allow delete: if isAdmin();
    }

    // ===============================================================
    // Appointments
    // ===============================================================
    match /appointments/{appointmentId} {
      allow read: if hasAccess();
      allow create: if hasAccess() && request.resource.data.keys().hasAll(['patient_id', 'date_rdv', 'heure_rdv', 'statut', 'created_by', 'created_at', 'updated_at']);
      allow update: if hasAccess();
      allow delete: if hasAccess();
    }

    // ===============================================================
    // Consultations
    // ===============================================================
    match /consultations/{consultationId} {
      allow read: if hasAccess();
      allow create: if hasAccess() && request.resource.data.keys().hasAll(['patient_id', 'date_consultation', 'created_by', 'created_at', 'updated_at']) && (
        !isAssistante() ||
        request.resource.data.keys().hasOnly(['patient_id', 'date_consultation', 'created_by', 'created_at', 'updated_at', 'poids', 'commentaire_assistante'])
      );
      allow update: if hasAccess() && (
        !isAssistante() ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'patient_id', 'date_consultation', 'poids', 'commentaire_assistante', 'updated_at'
          ])
        )
      );
      allow delete: if isAdmin();
    }

    // ===============================================================
    // Prescriptions
    // ===============================================================
    match /prescriptions/{prescriptionId} {
      allow read: if hasAccess();
      allow create: if hasAccess() && !isAssistante() && request.resource.data.keys().hasAll(['consultation_id', 'patient_id', 'date_prescription', 'created_by', 'created_at']);
      allow update: if hasAccess() && !isAssistante();
      allow delete: if isAdmin();
    }

    match /prescription_lines/{lineId} {
      allow read: if hasAccess();
      allow create: if hasAccess() && !isAssistante() && request.resource.data.keys().hasAll(['prescription_id', 'posologie', 'ordre_affichage']);
      allow update: if hasAccess() && !isAssistante();
      allow delete: if hasAccess() && !isAssistante();
    }

    // ===============================================================
    // Médicaments
    // ===============================================================
    match /medicaments/{medicamentId} {
      allow read: if hasAccess();
      allow create: if isAdmin() || isMedecin();
      allow update: if isAdmin() || isMedecin();
      allow delete: if isAdmin();
    }

    // ===============================================================
    // Examens
    // ===============================================================
    match /exams/{examId} {
      allow read: if hasAccess();
      allow create: if hasAccess() && !isAssistante() && request.resource.data.keys().hasAll(['patient_id', 'type_examen', 'date_demande', 'statut', 'created_by', 'created_at']);
      allow update: if hasAccess() && !isAssistante();
      allow delete: if isAdmin();
    }

    // ===============================================================
    // Documents
    // ===============================================================
    match /documents/{documentId} {
      allow read: if hasAccess();
      allow create: if hasAccess() && request.resource.data.keys().hasAll(['patient_id', 'nom_fichier', 'url_fichier', 'uploaded_by', 'created_at']);
      allow update: if hasAccess();
      allow delete: if isAdmin();
    }

    // ===============================================================
    // Paiements
    // ===============================================================
    match /payments/{paymentId} {
      allow read: if hasAccess();
      allow create: if hasAccess() && request.resource.data.keys().hasAll(['patient_id', 'montant', 'mode_paiement', 'statut_paiement', 'date_paiement', 'created_by', 'created_at']);
      allow update: if hasAccess();
      allow delete: if isAdmin();
    }

    // ===============================================================
    // Tags
    // ===============================================================
    match /tags/{tagId} {
      allow read: if hasAccess();
      allow create: if hasAccess() && request.resource.data.keys().hasAll(['nom', 'couleur', 'actif']);
      allow update: if hasAccess();
      allow delete: if isAdmin();
    }

    match /patient_tags/{patientTagId} {
      allow read: if hasAccess();
      allow create: if hasAccess() && request.resource.data.keys().hasAll(['patient_id', 'tag_id', 'date_attribution', 'attribue_par']);
      allow update: if hasAccess();
      allow delete: if hasAccess();
    }
  }
}
